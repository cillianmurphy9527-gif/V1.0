generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(uuid())
  phone            String?   @unique
  phoneVerified    DateTime?
  email            String?   @unique // 用于 NextAuth
  password         String? // 用于 NextAuth
  companyName      String
  name             String? // 用户名（联系人姓名）
  image            String? // 头像 URL
  industry         String? // 所属行业
  website          String? // 公司官网
  businessDesc     String? // 业务描述
  ragContext       String?
  credits          Int       @default(0)
  addonCredits     Int       @default(0) // 增值服务算力包余额
  extraDomains     Int       @default(0) // 额外购买的域名数量
  referralCode     String?   @unique // 专属邀请码
  referredById     String? // 推荐人ID
  subscriptionTier String // STARTER, PRO, MAX, TRIAL
  features         Json // {"canUseInbox": true, "aiScoring": true}
  role             String    @default("USER") // 用户角色: USER | ADMIN
  adminRole        String? // 约定只存入 "SUPER_ADMIN", "FINANCE", "OPS" 等字符串
  trialEndsAt      DateTime? // 7天试用到期时间（注册时自动设置）

  // ─── 配额核销字段 ──────────────────────────────────
  tokenBalance    Int       @default(0) // 剩余算力（tokens）
  monthlySearches Int       @default(0) // 本月已搜索次数
  ragFileCount    Int       @default(0) // 已解析知识库文件数
  monthlyResetAt  DateTime? // 本月配额重置时间

  // ─── 合规发信与风控字段 ──────────────────────────────
  bounceCount        Int     @default(0) // 退信数量（累计）
  isSendingSuspended Boolean @default(false) // 是否因退信率过高被暂停发信
  unsubscribed       Boolean @default(false) // 用户主动退订，不再接收任何邮件

  // ─── 防薅羊毛与反欺诈字段 ────────────────────────────
  registerIp        String? // 注册时的 IP 地址
  deviceFingerprint String? // 设备指纹

  // ─── 三道锁导出计费字段 ──────────────────────────────
  planType        String @default("FREE") // 套餐类型：FREE(免费/试运营), GROWTH(增长版), FLAGSHIP(旗舰版)
  exportCredits   Int    @default(0) // 商城购买的导出额度余额
  usedFreeExports Int    @default(0) // 本月已使用的免费导出额度（仅旗舰版）

  // ─── 线索库导出额度 ─────────────────────────────────
  exportQuota Int @default(50) // 线索导出额度（默认赠送50条）

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  domains             Domain[]
  campaigns           Campaign[]
  threads             EmailThread[]
  notifications       Notification[]
  orders              Order[]
  coupons             Coupon[] // 优惠券卡包
  knowledgeBases      KnowledgeBase[]
  tickets             Ticket[]             @relation("UserTickets")
  adminTickets        Ticket[]             @relation("AdminTickets")
  referredBy          User?                @relation("Referrals", fields: [referredById], references: [id])
  referrals           User[]               @relation("Referrals")
  systemNotifications SystemNotification[]
  broadcastMessages   BroadcastMessage[]
  dismissedBroadcasts DismissedBroadcast[]
  deviceFingerprints  DeviceFingerprint[]
  sendingLogs         SendingLog[]
  wallet              Wallet?
  userAssets          UserAsset[]
  siteMessages        SiteMessage[]
  novaTasks           NovaTask[]
  deliveryLogs        DeliveryLog[]
  userLeads           UserLead[]
  systemCostLogs      SystemCostLog[] // 关联用户的真实成本消耗记录
}

// ─── Nova 战术配置任务（Dashboard 战术面板持久化）────────────────
enum NovaTaskStatus {
  IDLE
  RUNNING
  COMPLETED
  FAILED
}

model NovaTask {
  id             String         @id @default(uuid())
  userId         String
  targetCountry  String
  targetIndustry String
  decisionMaker  String
  pitch          String
  status         NovaTaskStatus @default(IDLE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  deliveryLogs DeliveryLog[]
  sendingLogs  SendingLog[] // 🌟 修复：补充与 SendingLog 的反向关系

  @@index([userId])
  @@index([status])
}

model Wallet {
  id           String   @id @default(uuid())
  userId       String   @unique
  emailCredits Int      @default(0)
  leadCredits  Int      @default(0)
  aiTokens     Int      @default(0)
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserAsset {
  id         String   @id @default(uuid())
  userId     String
  assetType  String // 如 TEMPLATE_MECHANICAL, STRATEGY_PACK
  unlockedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([assetType])
}

model SiteMessage {
  id        String   @id @default(uuid())
  userId    String
  type      String   @default("NORMAL") // 约定只存入 "NORMAL", "FORCE_ALERT" 等字符串
  title     String
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([type])
}

model Domain {
  id             String    @id @default(uuid())
  userId         String
  domainName     String
  status         String // ACTIVE, BANNED, PENDING_DNS, PURCHASING, EMAIL_READY, WARMING_UP
  dailySentCount Int       @default(0)
  warmupEnabled  Boolean   @default(false) // 是否启用预热
  warmupDay      Int       @default(0) // 预热第几天（0 = 未启用）
  warmupScore    Int       @default(0) // 预热信誉分 (0-100)
  isReady        Boolean   @default(false) // 是否已达标可安全发信
  dailyLimit     Int       @default(20) // 预热期间每日上限
  sentToday      Int       @default(0) // 今日已发送数
  lastSentAt     DateTime? // 最后发送时间
  
  emailAccount   String?   // 存放 cPanel 自动建好的邮箱账号
  successId      String?   // 存放推送到 Success.ai/Smartlead 后的唯一账号 ID
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Campaign {
  id                String        @id @default(uuid())
  userId            String
  name              String
  systemPrompt      String
  status            String // IDLE, RUNNING, PAUSED_OUT_OF_CREDITS, PAUSED_NO_DOMAINS, COMPLETED, STOPPED
  estimatedLeads    Int           @default(0) // 预估触达数量
  tokensPerLead     Int           @default(100) // 每个线索消耗的 Token
  totalTokensNeeded Int           @default(0) // 本次任务总需 Token
  warmupEnabled     Boolean       @default(false) // 是否启用域名预热
  dailyLimit        Int           @default(0) // 每日发信上限（0 = 无限制）
  config            Json? // 活动扩展配置
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  leads             Lead[]
  agentSession      AgentSession?
}

model Lead {
  id          String   @id @default(uuid())
  campaignId  String
  email       String
  websiteData String?
  aiScore     Int?
  status      String // PENDING, FILTERED_LOW_INTENT, QUEUED, SENT, BOUNCED, UNSUBSCRIBED, REPLIED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model EmailThread {
  id          String         @id @default(uuid())
  userId      String
  targetEmail String // 收件人邮箱
  targetName  String? // 收件人姓名
  subject     String // 邮件主题
  status      String         @default("PENDING") // PENDING, REPLIED, CLOSED
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    EmailMessage[]
}

model EmailMessage {
  id          String      @id @default(uuid())
  threadId    String
  from        String // 发件人邮箱
  to          String // 收件人邮箱
  subject     String // 邮件主题
  body        String // 邮件正文
  sentAt      DateTime    @default(now()) // 发送时间
  isFromUser  Boolean     @default(false) // 是否是用户发送的
  createdAt   DateTime    @default(now())
  thread      EmailThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String // NEW_REPLY, SYSTEM_ALERT
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Order {
  id              String  @id @default(uuid())
  userId          String
  tradeNo         String? @unique // 订单流水号（唯一）
  amount          Float // 订单金额
  plan            String // 套餐名称: STARTER, PRO, MAX
  orderType       String // SUBSCRIPTION, ADDON
  status          String // PENDING, PAID, FAILED, CANCELED, REFUNDED
  refundStatus    String  @default("NONE") // NONE, REQUESTED, APPROVED, REJECTED, COMPLETED
  refundReason    String? // 退款原因
  rejectReason    String? // 驳回原因
  paymentIntentId String? // 支付网关真实流水号
  receiptSent     Boolean @default(false) // 是否已发送凭证

  tokensAllocated   Int @default(0)
  searchesAllocated Int @default(0)
  ragFilesAllocated Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([refundStatus])
}

model Coupon {
  id                String    @id @default(uuid())
  userId            String
  discountAmount    Int
  isUsed            Boolean   @default(false)
  sourceDescription String
  validUntil        DateTime
  usedAt            DateTime?
  usedOrderId       String?
  createdAt         DateTime  @default(now())
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model KnowledgeBase {
  id            String          @id @default(uuid())
  userId        String
  name          String
  description   String?
  fileType      String // PDF | WORD | LINK
  fileUrl       String?
  sourceUrl     String?
  parseStatus   String          @default("PENDING") // PENDING | PARSING | READY | FAILED
  chunkCount    Int             @default(0)
  vectorizedAt  DateTime?
  fileSizeBytes Int?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks        DocumentChunk[]
}

model DocumentChunk {
  id              String        @id @default(uuid())
  knowledgeBaseId String
  content         String
  embedding       Json?
  chunkIndex      Int
  tokenCount      Int           @default(0)
  createdAt       DateTime      @default(now())
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
}

model Ticket {
  id         String    @id @default(uuid())
  userId     String
  adminId    String?
  title      String
  type       String
  status     String    @default("OPEN")
  priority   String    @default("NORMAL")
  messages   Json
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation("UserTickets", fields: [userId], references: [id], onDelete: Cascade)
  admin      User?     @relation("AdminTickets", fields: [adminId], references: [id])
}

model SystemNotification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  content   String
  type      String   @default("SYSTEM")
  isRead    Boolean  @default(false)
  actionUrl String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model BroadcastMessage {
  id          String    @id @default(uuid())
  adminId     String
  title       String
  content     String
  targetPlan  String?
  sentCount   Int       @default(0)
  status      String    @default("DRAFT")
  scheduledAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  admin       User      @relation(fields: [adminId], references: [id])
}

model DismissedBroadcast {
  id          String   @id @default(uuid())
  userId      String
  broadcastId String
  isRead      Boolean  @default(false)
  isDismissed Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, broadcastId])
  @@index([userId])
}

model SystemSettings {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  category    String
  description String?
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}

model FinancialMetrics {
  id            String   @id @default(uuid())
  date          DateTime
  totalRevenue  Float    @default(0)
  mrr           Float    @default(0)
  starterSales  Int      @default(0)
  proSales      Int      @default(0)
  maxSales      Int      @default(0)
  totalTokens   Int      @default(0)
  totalEmails   Int      @default(0)
  estimatedCost Float    @default(0)
  grossProfit   Float    @default(0)
  profitMargin  Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([date])
}

model AgentConfig {
  id              String    @id @default(uuid())
  name            String
  type            String
  endpoint        String?
  status          String    @default("ACTIVE")
  lastHealthCheck DateTime?
  metrics         Json
  config          Json
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model DeviceFingerprint {
  id           String   @id @default(uuid())
  userId       String
  ipAddress    String
  fingerprint  String
  userAgent    String?
  trialClaimed Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([ipAddress])
  @@index([fingerprint])
  @@index([trialClaimed])
}

model IpBlacklist {
  id        String    @id @default(uuid())
  ipAddress String    @unique
  reason    String
  blockedAt DateTime  @default(now())
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([ipAddress])
}

model IpRegistrationLog {
  id           String   @id @default(uuid())
  ipAddress    String
  userId       String
  userEmail    String
  registeredAt DateTime @default(now())

  @@unique([ipAddress, userId])
  @@index([ipAddress])
  @@index([userId])
}

model UnsubscribeList {
  id             String   @id @default(uuid())
  email          String   @unique
  reason         String?
  unsubscribedAt DateTime @default(now())
  source         String   @default("USER_REQUEST")
  createdAt      DateTime @default(now())

  @@index([email])
}

model SendingLog {
  id             String    @id @default(cuid())
  userId         String
  taskId         String?
  leadId         String?
  recipientEmail String
  senderDomain   String
  fromEmail      String    @default("") 
  subject        String
  status         String    @default("SENT")

  companyName  String?
  contactName  String?
  openCount    Int       @default(0)
  clickCount   Int       @default(0)
  messageId    String?   
  errorMessage String?
  metadata     Json?     

  sentAt    DateTime  @default(now())
  openedAt  DateTime? 
  clickedAt DateTime? 
  repliedAt DateTime? 
  createdAt DateTime  @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  novaTask NovaTask? @relation(fields: [taskId], references: [id])
  lead     UserLead? @relation(fields: [leadId], references: [id])

  @@index([userId])
  @@index([taskId])
  @@index([leadId])
  @@index([status])
  @@index([sentAt])
  @@index([companyName])
}

model DeliveryLog {
  id             String  @id @default(cuid())
  userId         String
  taskId         String?
  leadId         String? // 关联的 UserLead（如有）
  recipientEmail String
  senderDomain   String
  subject        String
  status         String  @default("SENT") // SENT | DELIVERED | OPENED | CLICKED | REPLIED | BOUNCED | FAILED

  // ─── 高价值情报字段 ──────────────────────────────
  companyName  String? // 公司名称
  contactName  String? // 联系人姓名
  openCount    Int     @default(0) // 邮件被打开次数
  clickCount   Int     @default(0) // 链接被点击次数
  errorMessage String? // 发送失败/退信的具体原因

  sentAt    DateTime @default(now())
  createdAt DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  novaTask NovaTask? @relation(fields: [taskId], references: [id])
  lead     UserLead? @relation(fields: [leadId], references: [id])

  @@index([userId])
  @@index([taskId])
  @@index([leadId])
  @@index([status])
  @@index([sentAt])
  @@index([companyName])
}

model VerificationCode {
  id        String   @id @default(uuid())
  phone     String
  code      String
  used      Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
  @@index([phone, code])
}

model TokenTransaction {
  id            String   @id @default(uuid())
  userId        String
  campaignId    String?
  amount        Int
  reason        String
  balanceBefore Int
  balanceAfter  Int
  status        String   @default("COMPLETED")
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([campaignId])
  @@index([createdAt])
}

model AgentSession {
  id                String    @id @default(uuid())
  userId            String
  campaignId        String    @unique
  status            String
  estimatedLeads    Int
  totalTokensNeeded Int
  tokensUsed        Int       @default(0)
  emailsSent        Int       @default(0)
  emailsBounced     Int       @default(0)
  startedAt         DateTime?
  pausedAt          DateTime?
  resumedAt         DateTime?
  completedAt       DateTime?
  errorMessage      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  campaign          Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model LeadsCache {
  id           String   @id @default(uuid())
  userId       String
  domain       String
  companyName  String?
  contactEmail String   @unique
  jobTitle     String?
  isValid      Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([domain])
  @@index([isValid])
}

// 🌟 新增：全局防线 - 全局验证缓存池 (Global Verification Cache)
model GlobalLeadCache {
  id           String   @id @default(uuid())
  domain       String   // 公司域名 (如 apple.com)
  contactEmail String   @unique // 验证通过的有效邮箱
  firstName    String?
  lastName     String?
  companyName  String?
  jobTitle     String?
  source       String   @default("ZEROBOUNCE") // 数据来源/验证方
  confidence   Int      @default(100) // 置信度分数
  lastVerified DateTime @default(now()) // 最后一次验证有效的时间
  createdAt    DateTime @default(now())

  @@index([domain])
  @@index([contactEmail])
}

// 🌟 升级：细粒度控制 - 用户的独立资源配额大盘
model UserQuota {
  id           String   @id @default(uuid())
  userId       String   @unique
  tier         String   @default("STARTER")
  leadsBalance Int      @default(0) // 线索剩余可用余额
  leadsLimit   Int      @default(300) // 周期线索上限
  tokensLimit  Int      @default(50000) // 周期算力上限
  apiCostTotal Float    @default(0) 

  // --- 👇 新增细粒度控制字段，用于配额哨兵拦截 ---
  emailAccountsLimit Int @default(1) // 允许绑定的发信邮箱数量上限
  dailySendLimit     Int @default(1000) // 每日发信数量总上限
  exportBalance      Int @default(0) // 明文导出额度余额

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@index([tier])
}

// 🌟 新增：CMS 套餐细粒度配置模具 (Plan Template)
model PlanTemplate {
  id                 String   @id @default(uuid())
  planCode           String   @unique // 枚举：FREE, STARTER, PRO, MAX
  name               String   // 展示名称
  price              Float    // 价格
  leadsLimit         Int      // 模版：线索挖掘上限
  emailAccountsLimit Int      // 模版：发信账号上限
  dailySendLimit     Int      // 模版：每日发信额度上限
  exportQuota        Int      @default(0) // 模版：赠送的导出额度
  features           Json     // 模版：其他开关型权益 {"canUseInbox": true, "aiScoring": true}
  isActive           Boolean  @default(true) // 是否上架
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model NovaJob {
  id              String    @id @default(uuid())
  userId          String
  status          String    @default("PENDING")
  jobType         String
  totalTargets    Int       @default(0)
  currentProgress Int       @default(0)
  leadsFound      Int       @default(0)
  leadsSaved      Int       @default(0)
  errorMessage    String?
  logs            Json      @default("[]")
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([status])
}

model FixedCost {
  id           String   @id @default(uuid())
  name         String
  category     String
  amount       Float
  billingCycle String
  vendor       String?
  notes        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
  @@index([isActive])
}

model UserLead {
  id          String  @id @default(uuid())
  userId      String
  companyName String
  contactName String?
  jobTitle    String?
  country     String?
  email       String
  source      String  @default("NOVA")
  isUnlocked  Boolean @default(false)

  website   String?
  linkedIn  String?
  phone     String?
  industry  String?
  aiSummary String?

  createdAt DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveryLogs DeliveryLog[]
  sendingLogs  SendingLog[] // 🌟 修复：补充与 SendingLog 的反向关系

  @@unique([userId, email])
  @@index([userId])
  @@index([country])
  @@index([createdAt])
  @@index([isUnlocked])
}

model SystemCostLog {
  id          String   @id @default(cuid())
  provider    String
  feature     String?
  userId      String?
  usageAmount Int
  usageUnit   String
  costCny     Float
  costUsd     Float?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([provider])
  @@index([createdAt])
  @@index([userId])
}

model MonitoringNode {
  id          String   @id @default(uuid())
  name        String
  category    String
  envKey      String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([isActive])
}