# ─── Admin 物理级隔离 ────────────────────────────────────────
# 生产环境：设置为专属安全 IP+端口，如 "10.0.0.1:9999"
# 黑客用主域名访问 /admin 将直接看到 404，仿佛页面不存在
ALLOWED_ADMIN_HOST="127.0.0.1:9999"

# ─── NextAuth ────────────────────────────────────────────────
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="https://yourdomain.com"

# ─── Database（本地 Docker：docker compose -f docker-compose.dev.yml up -d）───
DATABASE_URL="postgresql://leadpilot:leadpilot_dev@localhost:5432/leadpilot"

# ─── Redis（与 docker-compose.dev.yml 中 redis:6379 一致）──────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Cloudflare Turnstile（人机验证）────────────────────────
# 不填则优雅降级，注册/登录按钮直接可用
# 从 https://dash.cloudflare.com/ → Turnstile 申请
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
